# Backend
OPENAI_API_KEY=your_openai_api_key_here
DATABASE_PATH=astrology.db
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend
# BACKEND_URL is used by Next.js on the server for rewrites and server-side fetches.
BACKEND_URL=http://127.0.0.1:8000

# NEXT_PUBLIC_API_URL is optional. Leave it unset for local use so the browser uses /api,
# which Next.js will proxy to BACKEND_URL. Set it only if your browser should call an
# external backend directly, like a deployed API URL.
# NEXT_PUBLIC_API_URL=https://your-backend.example.com
